# ─────────────────────────────────────────────────────────────────────────────
# CareerConnect — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

FLASK_APP=app.py
FLASK_ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_string

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Option A — full connection string (used by Render automatically):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# Option B — individual variables for local development:
#   PG_USER=postgres
#   PG_PASSWORD=postgres
#   PG_HOST=localhost
#   PG_PORT=5432
#   PG_DB=placement_portal
#
DATABASE_URL=postgresql://<username>:<password>@<host>/placement_portal

# ── Mail (SMTP) ────────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── LinkedIn OAuth 2.0 ───────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://127.0.0.1:8080/linkedin/callback

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
